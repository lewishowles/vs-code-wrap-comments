{
	"name": "wrap-comments",
	"displayName": "Wrap comments",
	"publisher": "LewisHowles",
	"version": "1.0.0",
	"description": "Comments look better, to me, wrapped at 80 characters. This plugin re-flows a comment to do just that, so you don’t have to think about it.",
	"main": "./extension.js",
	"icon": "assets/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/lewishowles/wrap-comments.git"
	},
	"contributes": {
		"commands": [
			{
				"command": "wrap-comments.wrapComment",
				"title": "Wrap comment"
			}
		],
		"configuration": {
			"properties": {
				"wrapComments.lineLength": {
					"type": "number",
					"default": 80,
					"description": "Line length to wrap comments to"
				}
			}
		}
	},
	"engines": {
		"vscode": "^1.92.0"
	},
	"scripts": {
		"lint": "eslint .",
		"test": "vitest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@vitest/ui": "latest",
		"eslint": "^10.2.1",
		"globals": "^17.5.0",
		"vitest": "^4.1.5"
	}
}
